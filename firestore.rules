rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir acceso a todas las colecciones principales del CMS
    // En desarrollo permitimos lectura/escritura general para facilitar el prototipado.
    
    match /devices/{deviceId} {
      allow read, write: if true;
    }

    match /stores/{storeId} {
      allow read, write: if true;
    }

    match /regions/{regionId} {
      allow read, write: if true;
    }

    match /sponsors/{sponsorId} {
      allow read, write: if true;
    }

    match /campaigns/{campaignId} {
      allow read, write: if true;
    }

    match /media/{mediaId} {
      allow read, write: if true;
    }

    match /playbackLogs/{logId} {
      allow read, write: if true;
    }

    match /playback/{docId} {
      allow read, write: if true;
    }

    match /generatedPlaylists/{playlistId} {
      allow read, write: if true;
    }
  }
}